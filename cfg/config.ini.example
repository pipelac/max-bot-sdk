; =============================================================================
; Конфигурация MAX Bot API SDK
; =============================================================================
;
; Скопируйте этот файл как config.ini и укажите свой токен.
; Документация: https://dev.max.ru/docs-api
;
; =============================================================================

[max]
; Токен бота (обязательно). Получите на https://max.ru через BotFather.
token = "YOUR_BOT_TOKEN_HERE"

; Таймаут HTTP-запросов (секунды). Допустимо: 5-300.
timeout = 30

; Количество повторных попыток при сетевых ошибках. Допустимо: 0-10.
retries = 3

; Лимит запросов в секунду (ограничение MAX API = 30). Допустимо: 1-100.
rate_limit = 30

; Проверка SSL-сертификатов (true/false).
verify_ssl = true

; Логировать успешные запросы (true/false).
log_requests = true

; Имя приложения для логов.
app_name = "MaxBot"

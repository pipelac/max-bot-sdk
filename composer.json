{
    "name": "app/max-bot-sdk",
    "description": "PHP SDK для MAX Bot API (platform-api.max.ru)",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=5.6",
        "ext-json": "*",
        "ext-mbstring": "*",
        "ext-curl": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0",
        "friendsofphp/php-cs-fixer": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "App\\Component\\Max\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Component\\Max\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "scripts": {
        "test": "phpunit --display-warnings",
        "analyse": "phpstan analyse",
        "cs-check": "php-cs-fixer fix --dry-run --diff",
        "cs-fix": "php-cs-fixer fix"
    }
}
